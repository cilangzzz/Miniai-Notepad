{
  "name": "miniai-notepad",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "dexie": "^3.2.4",
    "dexie-react-hooks": "^1.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.2.8",
    "vue-tsc": "^2.0.6",
    "typescript": "^5.4.2",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "vitest": "^1.4.0",
    "@vue/test-utils": "^2.4.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.3.1",
    "@typescript-eslint/eslint-plugin": "^7.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}